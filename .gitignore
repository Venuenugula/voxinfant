# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# ---- Virtual envs (NEVER commit these) ----
.venv/
venv/
env/
ENV/

# ---- Notebooks & papers (core research IP — keep local, never publish) ----
.ipynb_checkpoints/
*.ipynb
*.pdf

# ---- Data & model artifacts (large / regenerated) ----
data/
*.wav
*.mp3
*.csv
features/**/*.npy
features/**/*.pkl
features/*.npy
features/*.pkl
features/_colab_backup/
models/*.pkl
models/*.pt
models/*.npy
models/*.json
!models/.gitkeep
!features/.gitkeep
# Deployable trained artifacts (small ~2.3MB) are committed so cloud builds work.
!models/voxinfant_ensemble.pkl
!models/scaler.pkl
!models/label_classes.json

# ---- Uploads / runtime ----
uploads/
*.log

# ---- OS / editor ----
.DS_Store
